---
import AssetForm from '../components/AssetForm';
import { getSession } from '../lib/auth';

const session = await getSession(Astro.request);
if (!session) {
  return Astro.redirect('/api/auth/login');
}

const SNIPEIT_API_URL = (import.meta.env.SNIPEIT_API_URL || process.env.SNIPEIT_API_URL || '').replace(/\/$/, '');
const ACCESS_TOKEN = session.accessToken;

// Fetch current user info
let user: { name: string; username: string } | null = null;
try {
  const res = await fetch(`${SNIPEIT_API_URL}/users/me`, {
    headers: { 'Authorization': `Bearer ${ACCESS_TOKEN}`, 'Accept': 'application/json' },
  });
  if (res.ok) {
    user = await res.json();
  }
} catch (e) {
  console.error('Failed to fetch user info', e);
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>SnipeIT Asset Entry</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
	</head>
	<body>
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
			<div class="container">
				<a class="navbar-brand" href="/">SnipeIT Insert</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav ms-auto align-items-center">
						{user && (
							<li class="nav-item">
								<span class="nav-link text-light">
									Logged in as <strong>{user.name || user.username}</strong>
								</span>
							</li>
						)}
					</ul>
				</div>
			</div>
		</nav>
		<AssetForm client:load apiUrl="/api/proxy" accessToken={ACCESS_TOKEN} />
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
	</body>
</html>
