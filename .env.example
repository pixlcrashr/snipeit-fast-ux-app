# SnipeIT Configuration
SNIPEIT_API_URL=https://your-snipeit-instance.example.com/api/v1

# Public URL where this app is accessible (used for OAuth2 redirect URIs)
PUBLIC_URL=http://localhost:4321

# SnipeIT OAuth2 Configuration
SNIPEIT_OAUTH_CLIENT_ID=your-client-id
SNIPEIT_OAUTH_CLIENT_SECRET=your-client-secret
SNIPEIT_OAUTH_TOKEN_URL=https://your-snipeit-instance.example.com/oauth/token
SNIPEIT_OAUTH_AUTHORIZE_URL=https://your-snipeit-instance.example.com/oauth/authorize

# Session Configuration
SESSION_SECRET=a-very-long-secret-key-for-session-encryption

# Cookie Configuration (optional)
COOKIE_SAMESITE=lax # one of strict|lax|none
COOKIE_SECURE=true # one of true|false
COOKIE_HTTPONLY=true # one of true|false
