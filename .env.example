# SnipeIT API Configuration
SNIPEIT_API_URL=https://your-snipeit-instance.example.com/api/v1

# Public URL where this app is accessible (used for OAuth2 redirect URIs)
PUBLIC_URL=http://localhost:4321

# SnipeIT OAuth2 Configuration
SNIPEIT_OAUTH_CLIENT_ID=your-client-id
SNIPEIT_OAUTH_CLIENT_SECRET=your-client-secret

# Session Configuration
SESSION_SECRET=a-very-long-secret-key-for-session-encryption
